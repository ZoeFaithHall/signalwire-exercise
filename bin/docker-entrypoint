#!/bin/bash -e

# Only the web server needs the database on boot. One-off commands (bin/rubocop,
# bin/brakeman, bin/rails console) shouldn't block waiting on Postgres.
if [ "${1}" = "bin/rails" ] && [ "${2}" = "server" ]; then
  # Wait for PostgreSQL before touching the database.
  until pg_isready -h "${POSTGRES_HOST:-db}" -p "${POSTGRES_PORT:-5432}" -U "${POSTGRES_USER:-postgres}" >/dev/null 2>&1; do
    echo "Waiting for PostgreSQL at ${POSTGRES_HOST:-db}:${POSTGRES_PORT:-5432}..."
    sleep 1
  done

  # Create + migrate the database.
  bin/rails db:prepare
  rm -f tmp/pids/server.pid
fi

exec "${@}"
