<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Switchboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
  </head>

  <body>
    <header class="topbar">
      <div class="brand"><%= link_to "📞 Switchboard", root_path %></div>
      <% if logged_in? %>
        <nav class="nav">
          <%= link_to "Dashboard", dashboard_path %>
          <%= link_to "Admin", admin_path %>
          <%= button_to "Sign out", logout_path, method: :delete, class: "linkbtn" %>
        </nav>
      <% end %>
    </header>

    <main class="container">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
  </body>
</html>
